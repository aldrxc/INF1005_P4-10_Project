{
    "version": "0.2.0",
    "configurations": [
        {
            // -------------------------------------------------------
            // option a - launch site in browser (recommended daily use)
            // starts PHP dev server then opens http://localhost:8000
            // requires: built-in JS debugger (no extension needed)
            // -------------------------------------------------------
            "name": "MerchVault — Open in Browser",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8000/index.php",
            "preLaunchTask": "Start PHP Dev Server",
            "presentation": {
                "group": "dev",
                "order": 1
            }
        },
        {
            // -------------------------------------------------------
            // option b - same but using chrome instead of edge
            // -------------------------------------------------------
            "name": "MerchVault — Open in Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8000/index.php",
            "preLaunchTask": "Start PHP Dev Server",
            "presentation": {
                "group": "dev",
                "order": 2
            }
        },
        {
            // -------------------------------------------------------
            // option c - PHP + Xdebug (for step-debugging PHP)
            // requires: "PHP Debug" extension by Xdebug
            //   install: ext install xdebug.php-debug
            // also requires Xdebug installed in PHP:
            //   add to php.ini: zend_extension=xdebug
            //                   xdebug.mode=debug
            //                   xdebug.start_with_request=yes
            //                   xdebug.client_port=9003
            // -------------------------------------------------------
            "name": "MerchVault — PHP Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "preLaunchTask": "Start PHP Dev Server",
            "pathMappings": {
                "/": "${workspaceFolder}"
            },
            "presentation": {
                "group": "debug",
                "order": 1
            }
        }
    ],
    "compounds": [
        {
            // -------------------------------------------------------
            // compound - start server + open browser simultaneously
            // -------------------------------------------------------
            "name": "MerchVault — Full Dev (Server + Browser)",
            "configurations": ["MerchVault — Open in Browser"],
            "presentation": {
                "group": "dev",
                "order": 0
            }
        }
    ]
}
